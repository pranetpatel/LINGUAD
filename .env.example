VITE_SERVER_URL=https://api.lingua.family   # backend base URL (server/), no trailing slash

# ── Supabase mode (see SUPABASE_SETUP.md) ──
# Set VITE_APP_MODE=supabase to run against Supabase instead of server/.
# VITE_APP_MODE=supabase
# VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ── Family member email invites (optional, see SUPABASE_SETUP.md §6) ──
# Server-only — set these in Vercel's env config, NEVER in a local .env file.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # admin key, bypasses RLS — api/invite.js only
# SITE_URL=https://lingua.family

# ── AI provider (server-held keys, used by api/ai.js and server/ai.js) ──
# Either or both may be set. AI_PROVIDER picks which one serves /api/ai when
# both keys are present; Anthropic is preferred by default.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AI_PROVIDER=anthropic   # or "openai"
